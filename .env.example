# =========================
# 🚀 BLACKSTONE ENVIRONMENT
# =========================
# Este archivo contiene variables de entorno para desarrollo local.
# NO COMMIT este archivo - está en .gitignore
#
# Copia este archivo a .env para usar en desarrollo local:
# cp .env.example .env

# =========================
# 🔐 SECRETS / KEYS
# =========================
SECRET_KEY_BASE=tu_secret_key_base_aqui
DEVISE_SECRET_KEY=tu_devise_secret_key_aqui

# =========================
# 📧 OAUTH (Google, GitHub, etc.)
# =========================
# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=tu_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=tu_google_client_secret

# GitHub OAuth (futuro)
GITHUB_OAUTH_CLIENT_ID=tu_github_client_id
GITHUB_OAUTH_CLIENT_SECRET=tu_github_client_secret

# =========================
# 🗄️ DATABASE
# =========================
# PostgreSQL (para producción con URL)
# DATABASE_URL=postgres://user:password@localhost:5432/blackstone_production

# =========================
# ☁️ CLOUD STORAGE (Active Storage)
# =========================
# Amazon S3
# AWS_ACCESS_KEY_ID=tu_access_key
# AWS_SECRET_ACCESS_KEY=tu_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=blackstone-production

# Google Cloud Storage
# GCS_BUCKET=blackstone-production
# GOOGLE_CREDENTIALS=path/to/credentials.json

# =========================
# 📧 MAIL (ActionMailer)
# =========================
# SMTP
# SMTP_ADDRESS=smtp.gmail.com
# SMTP_PORT=587
# SMTP_DOMAIN=gmail.com
# SMTP_USERNAME=tu_email@gmail.com
# SMTP_PASSWORD=tu_app_password

# =========================
# 🎥 YOUTUBE API (futuro)
# =========================
# YOUTUBE_API_KEY=tu_youtube_api_key

# =========================
# 🔧 DEVELOPMENT
# =========================
# RAILS_ENV=development
# WEB_CONCURRENCY=2
