<div class="page-header">
  <p class="breadcrumb">
    <%= link_to "Inicio", root_path %> <span>/</span>
    <%= link_to "Cursos", courses_path %> <span>/</span>
    <%= @course.title %>
  </p>
  <h1><%= @course.title %></h1>
  <% if @course.description.present? %>
    <p style="max-width: 640px; font-size: 16px; line-height: 1.65;"><%= @course.description %></p>
  <% end %>
  <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px;">
    <span class="badge badge--purple"><%= @course.category&.name %></span>
    <% if @course.is_series %>
      <span class="badge badge--blue">📚 <%= @episodes.size %> episodios</span>
    <% else %>
      <span class="badge badge--yellow">🎬 Video único</span>
    <% end %>
  </div>
  <% if user_signed_in? %>
    <div style="margin-top: 16px;">
      <% if current_user.favorited_courses.include?(@course) %>
        <%= link_to "★ En favoritos", favorite_course_path(@course), data: { turbo_method: :delete }, class: "btn btn-secondary" %>
      <% else %>
        <%= link_to "☆ Agregar a favoritos", favorite_courses_path(course_id: @course.id), data: { turbo_method: :post }, class: "btn btn-secondary" %>
      <% end %>
    </div>
  <% end %>
</div>

<% if @episodes.any? %>
  <div class="course-episodes">
    <% @episodes.each do |episode| %>
      <%
        progress = @progresses[episode.id]
        start_at = progress ? progress.seconds_watched : 0
        is_completed = progress&.completed || false
      %>

      <div class="episode-card"
           data-controller="video-player"
           data-video-player-episode-id-value="<%= episode.id %>"
           data-video-player-youtube-id-value="<%= episode.youtube_id %>"
           data-video-player-start-at-value="<%= start_at %>"
           data-duration="<%= episode.duration_seconds || 0 %>">

        <div class="episode-card__header">
          <div>
            <% if @course.is_series %>
              <span class="episode-card__number">Ep. <%= episode.position %></span>
            <% end %>
            <h3 class="episode-card__title"><%= episode.title %></h3>
          </div>
          <span class="badge badge--green episode-completed-badge" style="<%= is_completed ? '' : 'display: none;' %>">✅ Completado</span>
        </div>

        <% if episode.youtube_id.present? %>
          <div class="episode-player">
            <% if user_signed_in? %>
              <div class="yt-player-container"></div>
              <% if start_at > 0 %>
                <p class="episode-resume">▶️ Retomando desde <%= start_at / 60 %>:<%= "%02d" % (start_at % 60) %></p>
              <% end %>
              <% if episode.duration_seconds && episode.duration_seconds > 0 %>
                <% percent = [(start_at.to_f / episode.duration_seconds * 100), 100].min %>
                <div class="progress-bar">
                  <div class="progress-bar__fill" style="width: <%= percent %>%;"></div>
                </div>
              <% end %>
            <% else %>
              <div class="episode-player__embed">
                <iframe src="https://www.youtube.com/embed/<%= episode.youtube_id %>"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen>
                </iframe>
              </div>
              <p class="episode-login-hint">
                💡 <%= link_to "Iniciá sesión", new_user_session_path %> para guardar tu progreso y retomar donde lo dejaste.
              </p>
            <% end %>
          </div>
        <% end %>

        <% if episode.duration_seconds && episode.duration_seconds > 0 %>
          <p class="episode-duration">⏱️ <%= episode.duration_seconds / 3600 %>h <%= (episode.duration_seconds % 3600) / 60 %>min</p>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="episode-empty">
    <div class="episode-empty__icon">🎬</div>
    <h3>Este curso aún no tiene episodios</h3>
    <p>El contenido del curso se publicará pronto. Volvé más tarde para ver los episodios.</p>
  </div>
<% end %>

<div style="margin-top: 2rem;">
  <%= link_to "← Volver a cursos", courses_path, class: "btn btn-secondary" %>
</div>
