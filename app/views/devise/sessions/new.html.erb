<div class="auth-container">
  <div class="auth-card">
    <h2>Iniciar sesión</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="modal-field">
        <%= f.label :email, "Correo electrónico" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "tu@email.com" %>
      </div>

      <div class="modal-field">
        <%= f.label :password, "Contraseña" %>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "Tu contraseña" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="modal-field" style="display: flex; align-items: center; gap: 0.5rem;">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "Recordarme" %>
        </div>
      <% end %>

      <div style="margin-top: 1.25rem;">
        <%= f.submit "Iniciar sesión", class: "btn btn-primary", style: "width: 100%;" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
