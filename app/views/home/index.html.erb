<% if @featured_item && @featured_item.tool %>
  <div class="featured-hero">
    <p class="featured-hero__label">🌟 Herramienta destacada del día</p>
    <h2><%= link_to @featured_item.tool.name, tool_path(@featured_item.tool) %></h2>
    <p><%= @featured_item.tool.description %></p>
    <div class="tool-card__badges" style="margin-top: 1rem;">
      <% if @featured_item.tool.open_source %>
        <span class="badge badge--green">🔓 Open Source</span>
      <% end %>
      <% if @featured_item.tool.free_tier %>
        <span class="badge badge--yellow">🆓 Free Tier</span>
      <% end %>
      <% if @featured_item.tool.platform.present? %>
        <span class="badge badge--blue"><%= @featured_item.tool.platform %></span>
      <% end %>
    </div>
    <div style="margin-top: 1.25rem;">
      <%= link_to "Ver herramienta →", tool_path(@featured_item.tool), class: "btn btn-primary" %>
    </div>
  </div>
<% end %>

<div class="page-header">
  <p class="section-title">Explorar categorías</p>
  <h1>Herramientas para Devs</h1>
  <p>Un directorio de herramientas seleccionadas para estudiantes de programación.</p>
</div>

<div class="categories-grid">
  <% @categories.each do |category| %>
    <div class="category-card">
      <%= link_to category.name, category_path(category) %>
      <% if category.description.present? %>
        <p><%= truncate(category.description, length: 80) %></p>
      <% end %>
    </div>
  <% end %>
</div>
