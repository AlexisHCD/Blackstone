<% if @featured_item && @featured_item.tool %>
  <div class="featured-hero" style="padding: 2rem; background: #f0f4f8; border-radius: 8px; margin-bottom: 2rem;">
    <h2>🌟 Herramienta destacada del día</h2>
    <h3><%= link_to @featured_item.tool.name, tool_path(@featured_item.tool) %></h3>
    <p><%= @featured_item.tool.description %></p>
    
    <div class="flags" style="margin-top: 1rem; font-size: 0.9em; color: #555;">
      <% if @featured_item.tool.open_source %>
        <span style="background: #e2f0cb; padding: 0.2rem 0.5rem; border-radius: 4px; margin-right: 0.5rem;">🔓 Open Source</span>
      <% end %>
      <% if @featured_item.tool.free_tier %>
        <span style="background: #ffebb5; padding: 0.2rem 0.5rem; border-radius: 4px;">🆓 Free Tier</span>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="featured-hero" style="padding: 2rem; background: #f0f4f8; border-radius: 8px; margin-bottom: 2rem;">
    <h2>🌟 Herramienta destacada del día</h2>
    <p>Aún no tenemos herramientas suficientes para destacar una hoy. ¡Vuelve pronto!</p>
  </div>
<% end %>

<hr style="margin: 2rem 0; border: 0; border-top: 1px solid #eee;">

<h1>Categorías</h1>

<ul>
  <% @categories.each do |category| %>
    <li>
      <%= link_to category.name, category_path(category) %>
    </li>
  <% end %>
</ul>
