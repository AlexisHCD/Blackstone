<%# ─── Premium Layered Glassmorphism Hero ─── %>
<section class="hero-premium" id="hero-tilt-area">
  <div class="hero-premium__bg"></div>

  <div class="hero-premium__container">
    <div class="hero-premium__content">
      <span class="hero-premium__badge">Herramienta destacada</span>

      <% if @featured_item && @featured_item.tool %>
        <h1 class="hero-premium__title"><%= @featured_item.tool.name %></h1>
        <p class="hero-premium__subtitle"><%= truncate(@featured_item.tool.description.presence || "Explorá esta herramienta seleccionada por la comunidad.", length: 100) %></p>
        <div class="hero-premium__actions">
          <%= link_to "Explorar →", tool_path(@featured_item.tool), class: "hero-premium__cta" %>
          <a href="<%= categories_path %>" class="hero-premium__ghost">Ver todas las categorías</a>
        </div>
        <div class="hero-premium__trust">
          <div class="hero-premium__trust-icon">⭐</div>
          <span class="hero-premium__trust-text">
            <% if @featured_item.tool.open_source %>Open Source<% else %>Popular<% end %>
            en <%= @featured_item.tool.category&.name || "la comunidad" %>
          </span>
        </div>
      <% else %>
        <h1 class="hero-premium__title">Blackstone</h1>
        <p class="hero-premium__subtitle">Directorio de herramientas y recursos seleccionados para estudiantes de programación.</p>
        <div class="hero-premium__actions">
          <%= link_to "Explorar →", categories_path, class: "hero-premium__cta" %>
        </div>
      <% end %>
    </div>

    <div class="hero-premium__visual" id="hero-visual-tilt">
      <div class="hero-premium__card-back"></div>
      <div class="hero-premium__card-front hero-premium__card-front-tilt" id="hero-tilt-card">
        <% if @featured_item && @featured_item.tool && @featured_item.tool.logo.attached? %>
          <div class="hero-premium__logo-wrapper">
            <%= image_tag @featured_item.tool.logo, class: "hero-premium__logo", alt: @featured_item.tool.name %>
          </div>
        <% else %>
          <div class="hero-premium__logo-placeholder">
            <%= @featured_item&.tool&.name.to_s.first(2).upcase.presence || "⬛" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ─── Categories Carousel ─── %>
<section class="carousel-section">
  <div class="carousel-noise"></div>

  <div class="carousel-header">
    <span class="carousel-badge">Explorar</span>
    <h2>Navegá por categorías</h2>
    <p>Herramientas y cursos seleccionados para cada área del desarrollo</p>
  </div>

  <div class="swiper categories-swiper" id="categories-swiper-el">
    <div class="swiper-wrapper">
      <% @categories.each_with_index do |category, idx| %>
        <%
          cat_words = category.name.split(/[\s&]+/)
          theme_idx = cat_words.find { |w| themes[w] } ? themes[cat_words.find { |w| themes[w] }] : (idx % 6)
          cat_svg   = cat_words.find { |w| svg_map[w] } ? svg_map[cat_words.find { |w| svg_map[w] }] : svg_dev
          cat_ill   = cat_words.find { |w| ill_map[w] } ? ill_map[cat_words.find { |w| ill_map[w] }] : ill_dev
          is_aprendizaje = category.name.match?(/Aprendizaje|Carrera/i)
          display_name = is_aprendizaje ? "Cursos para principiantes" : category.name
        %>
        <div class="swiper-slide">
          <a href="<%= category_path(category) %>" class="cyber-card" data-theme="<%= theme_idx %>">
            <div class="cyber-card__bg"></div>
            <div class="cyber-card__pattern"></div>
            <div class="cyber-card__illustration"><%= cat_ill %></div>
            <div class="cyber-card__overlay"></div>
            <div class="cyber-card__glass-bar"></div>
            <div class="cyber-card__content">
              <div class="cyber-card__icon"><%= cat_svg %></div>
              <h3 class="cyber-card__title"><%= display_name %></h3>
              <% if category.description.present? %>
                <p class="cyber-card__desc"><%= category.description %></p>
              <% end %>
              <div class="cyber-card__badges">
                <span class="cyber-badge"><%= category.tools.count %> Herramientas</span>
                <% if is_aprendizaje %>
                  <span class="cyber-badge"><%= category.courses.count %> Cursos</span>
                <% end %>
              </div>
              <span class="cyber-card__cta">
                Explorar <span class="cyber-card__arrow">→</span>
              </span>
            </div>
          </a>
        </div>
      <% end %>
    </div>
  </div>
</section>

<script>
  document.addEventListener('turbo:load', function() {
    if (window.categorySwiper) window.categorySwiper.destroy(true, true);

    window.categorySwiper = new Swiper('.categories-swiper', {
      slidesPerView: 'auto',
      spaceBetween: 24,
      grabCursor: true,
      freeMode: {
        enabled: true,
        momentum: true,
        momentumRatio: 0.5,
        momentumVelocityRatio: 0.5
      },
      mousewheel: { forceToAxis: true, sensitivity: 0.8 },
      breakpoints: {
        0: { spaceBetween: 16 },
        768: { spaceBetween: 24 },
        1200: { spaceBetween: 32 }
      }
    });

    var swiperEl = document.getElementById('categories-swiper-el');
    if (swiperEl && window.categorySwiper) {
      var edgeScrollId = null, mouseX = 0, edgeSpeed = 4;

      swiperEl.addEventListener('mousemove', function(e) {
        mouseX = e.clientX - swiperEl.getBoundingClientRect().left;
      });

      swiperEl.addEventListener('mouseenter', function() {
        if (edgeScrollId) return;
        (function loop() {
          var s = window.categorySwiper;
          if (!s || s.destroyed) { edgeScrollId = null; return; }
          var w = swiperEl.getBoundingClientRect().width;
          var leftEdge = w * 0.2, rightEdge = w * 0.8;
          if (mouseX < leftEdge) {
            s.setTranslate(s.getTranslate() + edgeSpeed * (1 - mouseX / leftEdge));
          } else if (mouseX > rightEdge) {
            s.setTranslate(s.getTranslate() - edgeSpeed * ((mouseX - rightEdge) / (w - rightEdge)));
          }
          edgeScrollId = requestAnimationFrame(loop);
        })();
      });

      swiperEl.addEventListener('mouseleave', function() {
        if (edgeScrollId) { cancelAnimationFrame(edgeScrollId); edgeScrollId = null; }
      });
    }
  });

  document.addEventListener('turbo:load', function() {
    const tiltArea = document.getElementById('hero-tilt-area');
    const tiltCard = document.getElementById('hero-tilt-card');
    if (!tiltArea || !tiltCard) return;
    tiltArea.addEventListener('mousemove', function(e) {
      const rect = tiltArea.getBoundingClientRect();
      const x = e.clientX - rect.left, y = e.clientY - rect.top;
      const centerX = rect.width / 2, centerY = rect.height / 2, maxTilt = 8;
      const rotateY = ((x - centerX) / centerX) * maxTilt;
      const rotateX = -((y - centerY) / centerY) * maxTilt;
      tiltCard.style.setProperty('--tilt-transform', `rotate3d(0, 1, 0, ${rotateY}deg) rotate3d(1, 0, 0, ${rotateX}deg)`);
      tiltCard.style.setProperty('--tilt-shadow', `${-rotateY * 0.15}px ${rotateX * 0.15}px 40px rgba(146, 129, 247, 0.15)`);
    }, { passive: true });
    tiltArea.addEventListener('mouseleave', function() {
      tiltCard.style.setProperty('--tilt-transform', 'rotate3d(0, 0, 0, 0deg)');
      tiltCard.style.setProperty('--tilt-shadow', '0 0 0 transparent');
    });
  });
</script>
