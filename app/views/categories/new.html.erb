<h1>Nueva categoría</h1>

<%= form_with model: @category do |f| %>
  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.submit "Crear categoría" %>
  </div>
<% end %>

<%= link_to "Volver", categories_path %>
