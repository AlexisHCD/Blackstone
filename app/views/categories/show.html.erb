<%# ─── SEO Meta Tags ─── %>
<% page_title "Herramientas de #{@category.name} | Blackstone" %>
<% page_description "Explora #{@category.tools.count} herramientas de #{@category.name} en Blackstone. #{@category.description}" %>

<%# ─── Breadcrumb Structured Data ─── %>
<% content_for :structured_data do %>
  <%= structured_data(:breadcrumb, [
    { name: "Inicio", url: root_url },
    { name: "Categorías", url: categories_url },
    { name: @category.name, url: category_url(@category) }
  ]) %>
<% end %>

<div class="page-header">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <ol itemscope itemtype="https://schema.org/BreadcrumbList">
      <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <%= link_to "Inicio", root_path, itemprop: "item" %>
        <meta itemprop="name" content="Inicio" />
        <meta itemprop="position" content="1" />
      </li>
      <span>/</span>
      <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <%= link_to "Categorías", categories_path, itemprop: "item" %>
        <meta itemprop="name" content="Categorías" />
        <meta itemprop="position" content="2" />
      </li>
      <span>/</span>
      <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <span itemprop="name"><%= @category.name %></span>
        <meta itemprop="position" content="3" />
      </li>
    </ol>
  </nav>
  <h1><%= @category.name %></h1>
  <% if @category.description.present? %>
    <p><%= @category.description %></p>
  <% end %>
</div>

<% if @category.tools.any? %>
  <div class="tools-grid">
    <% @category.tools.each do |tool| %>
      <div class="tool-card">
        <div class="tool-card__logo-wrapper">
          <% if tool.logo.attached? %>
            <%= image_tag tool.logo, class: "tool-card__logo", alt: tool.name %>
          <% else %>
            <div class="tool-card__logo-placeholder">🔧</div>
          <% end %>
        </div>

        <div class="tool-card__name">
          <%= link_to tool.name, tool_path(tool) %>
        </div>

        <% if tool.description.present? %>
          <p class="tool-card__description"><%= tool.description %></p>
        <% end %>

        <div class="tool-card__badges">
          <% if tool.open_source %>
            <span class="badge badge--green">Open Source</span>
          <% end %>
          <% if tool.free_tier %>
            <span class="badge badge--yellow">Free Tier</span>
          <% end %>
          <% if tool.platform.present? %>
            <span class="badge badge--blue"><%= tool.platform %></span>
          <% end %>
          <% if tool.level.present? %>
            <span class="badge badge--purple"><%= tool.level %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p>No hay herramientas aún en esta categoría.</p>
<% end %>

<div style="margin-top: 2rem;">
  <%= link_to "← Volver a categorías", categories_path, class: "btn btn-secondary" %>
</div>