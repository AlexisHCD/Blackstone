<div class="admin-header">
  <h1>Usuarios</h1>
  <p>Gestioná los usuarios registrados en la plataforma.</p>
</div>

<div class="admin-nav-strip">
  <%= link_to "← Dashboard", admin_root_path %>
</div>

<div class="admin-table-card">
  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Nombre</th>
        <th>Email</th>
        <th>Rol</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td class="cell-mono">#<%= user.id %></td>
          <td><strong><%= user.name.presence || "Sin nombre" %></strong></td>
          <td class="cell-muted"><%= user.email %></td>
          <td>
            <% if user.admin? %>
              <span class="badge badge--purple">Admin</span>
            <% else %>
              <span class="badge">Usuario</span>
            <% end %>
          </td>
          <td class="cell-actions">
            <% if user == current_user %>
              <span class="cell-muted">Sos vos</span>
            <% else %>
              <%= button_to user.admin? ? "Quitar admin" : "Hacer admin",
                    toggle_admin_admin_user_path(user),
                    method: :patch,
                    class: user.admin? ? "admin-btn-sm admin-btn-sm--danger" : "admin-btn-sm admin-btn-sm--success",
                    data: { turbo_confirm: "¿Cambiar rol de #{user.name || user.email}?" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
