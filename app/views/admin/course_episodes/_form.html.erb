<%= form_with model: [:admin, @course, episode], html: { class: "admin-form-card" } do |f| %>
  <% if episode.errors.any? %>
    <div class="admin-form-errors">
      <h3><%= pluralize(episode.errors.count, "error") %> impidieron guardar:</h3>
      <ul>
        <% episode.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="admin-field">
    <%= f.label :title, "Título del episodio" %>
    <%= f.text_field :title, placeholder: "Ej. Introducción al framework" %>
  </div>

  <div class="admin-field" style="padding: 16px; background: rgba(59, 158, 255, 0.04); border: 1px solid rgba(59, 158, 255, 0.15); border-radius: 10px;">
    <%= f.label :youtube_url, "🎥 URL del video en YouTube" %>
    <%= f.text_field :youtube_url, placeholder: "https://www.youtube.com/watch?v=dQw4w9WgXcQ" %>
    <small>Copiá y pegá el enlace del video. Formatos aceptados: youtube.com/watch?v=, youtu.be/, youtube.com/embed/</small>
  </div>

  <div class="admin-field">
    <%= f.label :duration_seconds, "⏱️ Duración del video (en segundos)" %>
    <%= f.number_field :duration_seconds, min: 0, placeholder: "Ej. 600 = 10 minutos" %>
    <small>Convertí los minutos a segundos. Ej: 10 min = 600, 1 hora = 3600.</small>
  </div>

  <div class="admin-field">
    <%= f.label :position, "#️⃣ Posición (orden)" %>
    <%= f.number_field :position, min: 1, value: (episode.position || @course.course_episodes.maximum(:position).to_i + 1) %>
    <small>El orden en que aparece el episodio en la serie. Se asigna automáticamente.</small>
  </div>

  <div class="admin-field--submit">
    <%= f.submit "Guardar Episodio", class: "btn btn-primary" %>
    <%= link_to "Cancelar", admin_course_path(@course), class: "btn btn-secondary" %>
  </div>
<% end %>
