<div class="admin-header">
  <h1>Cursos</h1>
  <p>Gestioná los cursos y tutoriales en video.</p>
</div>

<div class="admin-nav-strip">
  <%= link_to "← Dashboard", admin_root_path %>
  <span class="sep">|</span>
  <%= link_to "+ Nuevo Curso", new_admin_course_path %>
</div>

<div class="admin-table-card">
  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Título</th>
        <th>Categoría</th>
        <th>Tipo</th>
        <th>Episodios</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @courses.each do |course| %>
        <tr>
          <td class="cell-mono">#<%= course.id %></td>
          <td><strong><%= link_to course.title, admin_course_path(course) %></strong></td>
          <td><span class="admin-badge"><%= course.category&.name %></span></td>
          <td><%= course.is_series ? "📚 Serie" : "🎬 Video" %></td>
          <td class="cell-mono"><%= course.course_episodes.count %></td>
          <td class="cell-actions">
            <%= link_to "Episodios", admin_course_path(course), class: "admin-btn-sm admin-btn-sm--primary" %>
            <%= link_to "Editar", edit_admin_course_path(course), class: "admin-btn-sm admin-btn-sm--primary" %>
            <%= link_to "Eliminar", admin_course_path(course), class: "admin-btn-sm admin-btn-sm--danger",
                  data: { turbo_method: :delete, turbo_confirm: "¿Eliminar #{course.title}?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
