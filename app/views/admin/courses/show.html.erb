<div class="admin-header">
  <h1><%= @course.title %></h1>
</div>

<div class="admin-nav-strip">
  <%= link_to "← Cursos", admin_courses_path %>
  <span class="sep">|</span>
  <%= link_to "Editar", edit_admin_course_path(@course) %>
</div>

<div class="admin-detail-card">
  <p><strong>Categoría:</strong> <%= @course.category&.name || "—" %></p>
  <p><strong>Tipo:</strong> <%= @course.is_series ? "📚 Serie" : "🎬 Video único" %></p>
  <% if @course.description.present? %>
    <p><%= @course.description %></p>
  <% end %>
</div>

<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
  <h2 style="margin: 0;">Episodios (<%= @course.course_episodes.count %>)</h2>
  <%= link_to "+ Agregar Episodio", new_admin_course_course_episode_path(@course), class: "btn btn-primary" %>
</div>

<% if @course.course_episodes.any? %>
  <div class="admin-table-card">
    <table class="admin-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Título</th>
          <th>YouTube ID</th>
          <th>Duración</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @course.course_episodes.each do |ep| %>
          <tr>
            <td class="cell-mono"><%= ep.position %></td>
            <td><strong><%= ep.title %></strong></td>
            <td><code><%= ep.youtube_id %></code></td>
            <td class="cell-mono"><%= ep.duration_minutes %> min</td>
            <td class="cell-actions">
              <%= link_to "Editar", edit_admin_course_course_episode_path(@course, ep), class: "admin-btn-sm admin-btn-sm--primary" %>
              <%= link_to "Eliminar", admin_course_course_episode_path(@course, ep), class: "admin-btn-sm admin-btn-sm--danger",
                    data: { turbo_method: :delete, turbo_confirm: "¿Eliminar #{ep.title}?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div style="text-align: center; padding: 48px 32px; background: var(--surface-card-surface); border: 1px solid var(--surface-ui-rail); border-radius: 16px;">
    <div style="font-size: 40px; margin-bottom: 12px;">🎬</div>
    <h3 style="color: var(--color-frost); margin-bottom: 8px;">Sin episodios</h3>
    <p style="color: var(--color-fog); font-size: 14px; margin-bottom: 20px;">
      <% if @course.is_series %>
        Agregá episodios para construir la serie del curso.
      <% else %>
        Agregá el video de YouTube para completar este curso.
      <% end %>
    </p>
    <%= link_to "+ Agregar Episodio", new_admin_course_course_episode_path(@course), class: "btn btn-primary" %>
  </div>
<% end %>
