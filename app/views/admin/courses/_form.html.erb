<%= form_with model: [:admin, course], html: { class: "admin-form-card" } do |f| %>
  <% if course.errors.any? %>
    <div class="admin-form-errors">
      <h3><%= pluralize(course.errors.count, "error") %> impidieron guardar:</h3>
      <ul>
        <% course.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="admin-field">
    <%= f.label :title, "Título" %>
    <%= f.text_field :title, placeholder: "Ej. Aprende Ruby on Rails" %>
  </div>

  <div class="admin-field">
    <%= f.label :category_id, "Categoría" %>
    <%= f.collection_select :category_id, @categories, :id, :name, { prompt: "Seleccioná una categoría" } %>
  </div>

  <div class="admin-field">
    <%= f.label :description, "Descripción" %>
    <%= f.text_area :description, rows: 3, placeholder: "¿De qué trata este curso?" %>
  </div>

  <div class="admin-field admin-field--inline">
    <%= f.check_box :is_series %>
    <%= f.label :is_series, "¿Es una serie con múltiples episodios?" %>
    <small style="display: inline; margin: 0;">(si no, será un video único)</small>
  </div>

  <div class="admin-field--submit">
    <%= f.submit "Guardar Curso", class: "btn btn-primary" %>
    <%= link_to "Cancelar", admin_courses_path, class: "btn btn-secondary" %>
  </div>
<% end %>
