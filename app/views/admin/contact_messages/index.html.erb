<h1>📬 Mensajes de Contacto (<%= @unread_count %> sin leer)</h1>

<%= link_to "Volver al Dashboard", admin_root_path %>

<% if @messages.any? %>
  <table border="1" cellpadding="5" style="margin-top: 20px; width: 100%; text-align: left;">
    <thead>
      <tr>
        <th>Estado</th>
        <th>Tipo</th>
        <th>Nombre</th>
        <th>Email</th>
        <th>Mensaje (resumen)</th>
        <th>Fecha</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @messages.each do |msg| %>
        <tr style="<%= msg.read ? '' : 'font-weight: bold; background: #1e1b4b30;' %>">
          <td><%= msg.read ? "✅ Leído" : "🔵 Nuevo" %></td>
          <td><%= msg.message_type&.humanize %></td>
          <td><%= msg.name %></td>
          <td><%= msg.email %></td>
          <td><%= truncate(msg.body, length: 50) %></td>
          <td><%= msg.created_at.strftime("%d/%m/%Y %H:%M") %></td>
          <td>
            <%= link_to "Ver", admin_contact_message_path(msg) %> |
            <% unless msg.read %>
              <%= link_to "Marcar leído", mark_read_admin_contact_message_path(msg), data: { turbo_method: :patch } %> |
            <% end %>
            <%= link_to "Eliminar", admin_contact_message_path(msg), data: { turbo_method: :delete, turbo_confirm: "¿Eliminar este mensaje?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p style="margin-top: 1rem;">No hay mensajes aún. 🎉</p>
<% end %>
