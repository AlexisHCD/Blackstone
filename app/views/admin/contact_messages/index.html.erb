<div class="admin-header">
  <h1>Mensajes de Contacto</h1>
  <p><%= @unread_count %> mensajes sin leer de <%= @messages.count %> totales.</p>
</div>

<div class="admin-nav-strip">
  <%= link_to "← Dashboard", admin_root_path %>
</div>

<% if @messages.any? %>
  <div class="admin-table-card">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Estado</th>
          <th>Tipo</th>
          <th>Nombre</th>
          <th>Email</th>
          <th>Mensaje</th>
          <th>Fecha</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @messages.each do |msg| %>
          <tr class="<%= 'row-highlight' unless msg.read? %>">
            <td>
              <span class="admin-status <%= msg.read? ? 'admin-status--read' : 'admin-status--unread' %>">
                <%= msg.read? ? "Leído" : "Nuevo" %>
              </span>
            </td>
            <td><span class="admin-badge"><%= msg.message_type&.humanize %></span></td>
            <td><strong><%= msg.name %></strong></td>
            <td class="cell-muted"><%= msg.email %></td>
            <td class="cell-muted"><%= truncate(msg.body, length: 50) %></td>
            <td class="cell-mono"><%= msg.created_at.strftime("%d/%m/%Y") %></td>
            <td class="cell-actions">
              <%= link_to "Ver", admin_contact_message_path(msg), class: "admin-btn-sm admin-btn-sm--primary" %>
              <% unless msg.read? %>
                <%= link_to "Marcar leído", mark_read_admin_contact_message_path(msg),
                      class: "admin-btn-sm admin-btn-sm--success",
                      data: { turbo_method: :patch } %>
              <% end %>
              <%= link_to "Eliminar", admin_contact_message_path(msg),
                    class: "admin-btn-sm admin-btn-sm--danger",
                    data: { turbo_method: :delete, turbo_confirm: "¿Eliminar mensaje de #{msg.name}?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p style="color: var(--color-fog);">No hay mensajes todavía.</p>
<% end %>
