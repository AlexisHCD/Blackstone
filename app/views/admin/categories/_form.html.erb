<%= form_with model: [:admin, category], data: { turbo: false }, html: { class: "admin-form-card" } do |f| %>
  <% if category.errors.any? %>
    <div class="admin-form-errors">
      <h3><%= pluralize(category.errors.count, "error") %> impidieron guardar:</h3>
      <ul>
        <% category.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="admin-field">
    <%= f.label :name, "Nombre" %>
    <%= f.text_field :name, placeholder: "Ej. Desarrollo" %>
  </div>

  <div class="admin-field">
    <%= f.label :description, "Descripción" %>
    <%= f.text_area :description, rows: 3, placeholder: "Breve descripción de la categoría..." %>
  </div>

  <div class="admin-field--submit">
    <%= f.submit "Guardar Categoría", class: "btn btn-primary" %>
    <%= link_to "Cancelar", admin_categories_path, class: "btn btn-secondary" %>
  </div>
<% end %>
