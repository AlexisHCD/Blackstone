<%= form_with model: [:admin, tool], local: true, html: { class: "admin-form-card" } do |f| %>
  <% if tool.errors.any? %>
    <div class="admin-form-errors">
      <h3><%= pluralize(tool.errors.count, "error") %> impidieron guardar:</h3>
      <ul>
        <% tool.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="admin-field">
    <%= f.label :name, "Nombre" %>
    <%= f.text_field :name, placeholder: "Ej. VS Code" %>
  </div>

  <div class="admin-field">
    <%= f.label :category_id, "Categoría" %>
    <%= f.collection_select :category_id, @categories, :id, :name, { prompt: "Seleccioná una categoría" } %>
  </div>

  <div class="admin-field">
    <%= f.label :description, "Descripción" %>
    <%= f.text_area :description, rows: 3, placeholder: "¿Qué hace esta herramienta?" %>
    <small>Máximo 300 caracteres.</small>
  </div>

  <div class="admin-field">
    <%= f.label :logo, "Logo" %>
    <% if tool.logo.attached? %>
      <div style="margin-bottom: 8px;">
        <%= image_tag tool.logo, style: "width: 80px; height: 80px; object-fit: contain; border-radius: 12px; background: var(--surface-canvas); border: 1px solid var(--surface-ui-rail); padding: 8px;" %>
      </div>
    <% end %>
    <%= f.file_field :logo %>
  </div>

  <div class="admin-field">
    <%= f.label :website_url, "URL del sitio web" %>
    <%= f.text_field :website_url, placeholder: "https://..." %>
  </div>

  <div class="admin-field admin-field--inline">
    <%= f.check_box :open_source %>
    <%= f.label :open_source, "¿Es Open Source?" %>
  </div>

  <div class="admin-field admin-field--inline">
    <%= f.check_box :free_tier %>
    <%= f.label :free_tier, "¿Tiene Free Tier?" %>
  </div>

  <div class="admin-field">
    <%= f.label :platform, "Plataforma" %>
    <%= f.select :platform, Tool::PLATFORMS.map { |p| [p, p] }, { prompt: "Seleccioná..." } %>
  </div>

  <div class="admin-field">
    <%= f.label :level, "Nivel" %>
    <%= f.select :level, Tool::LEVELS.map { |l| [l, l] }, { prompt: "Seleccioná..." } %>
  </div>

  <div class="admin-field--submit">
    <%= f.submit "Guardar Herramienta", class: "btn btn-primary" %>
    <%= link_to "Cancelar", admin_tools_path, class: "btn btn-secondary" %>
  </div>
<% end %>
