<div class="admin-header">
  <h1>Herramientas</h1>
  <p>Gestioná el directorio de herramientas para desarrolladores.</p>
</div>

<div class="admin-nav-strip">
  <%= link_to "← Dashboard", admin_root_path %>
  <span class="sep">|</span>
  <%= link_to "+ Nueva Herramienta", new_admin_tool_path %>
</div>

<div class="admin-table-card">
  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Logo</th>
        <th>Nombre</th>
        <th>Categoría</th>
        <th>Plataforma</th>
        <th>Nivel</th>
        <th>OSS</th>
        <th>Free</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @tools.each do |tool| %>
        <tr>
          <td class="cell-mono">#<%= tool.id %></td>
          <td><%= tool.logo.attached? ? "✅" : "—" %></td>
          <td><strong><%= link_to tool.name, tool_path(tool) %></strong></td>
          <td class="cell-muted"><%= tool.category&.name %></td>
          <td><span class="admin-badge"><%= tool.platform %></span></td>
          <td><span class="admin-badge"><%= tool.level %></span></td>
          <td><%= tool.open_source ? "✅" : "—" %></td>
          <td><%= tool.free_tier ? "✅" : "—" %></td>
          <td class="cell-actions">
            <%= link_to "Editar", edit_admin_tool_path(tool), class: "admin-btn-sm admin-btn-sm--primary" %>
            <%= link_to "Eliminar", admin_tool_path(tool), class: "admin-btn-sm admin-btn-sm--danger",
                  data: { turbo_method: :delete, turbo_confirm: "¿Eliminar #{tool.name}?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
