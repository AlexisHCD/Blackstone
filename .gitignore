# =========================
# 🔐 ENV / SECRETS
# =========================
.env*
!/.env*.erb
/config/master.key

# =========================
# 💎 RUBY / BUNDLER
# =========================
/.bundle
/vendor/bundle

# =========================
# 🧱 LOGS & TEMP FILES
# =========================
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# PID files
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# =========================
# 📦 STORAGE (ActiveStorage)
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# =========================
# ⚙️ ASSETS
# =========================
/public/assets
/public/packs
/node_modules
/yarn-error.log
npm-debug.log*
yarn-debug.log*

# =========================
# 🖥️ EDITORS / IDE
# =========================
.vscode/*
!.vscode/extensions.json
.idea
*.swp
*.swo
*~

# =========================
# 🐧 OS FILES
# =========================
.DS_Store
Thumbs.db

# =========================
# 🧪 TEST / COVERAGE
# =========================
/coverage

# =========================
# 🗄️ DATABASE (si usaras SQLite)
# =========================
*.sqlite3
*.sqlite3-journal

# =========================
# 🔧 MISC
# =========================
.byebug_history